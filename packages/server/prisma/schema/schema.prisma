generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * Tracks data migrations that have been run.
 * Used to ensure migrations only run once and to audit when they ran.
 */
model Migration {
  id String @id @default(uuid())

  // unique name of the migration (e.g., "encryptJournals")
  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
