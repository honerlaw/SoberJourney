/**
 * Represents a journal entry for a user.
 * Users can write personal reflections, thoughts, or notes
 * as part of their recovery journey.
 */
model JournalEntry {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
