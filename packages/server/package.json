{
  "name": "@onerlaw/soberjourney-server",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "test": "node --experimental-strip-types --experimental-test-module-mocks --experimental-test-coverage --import tsx --test **/*.test.mts",
    "start:local": "tsx --watch --no-cache --env-file=.env src/server.mts",
    "start:local:cron": "tsx --watch --no-cache --env-file=.env src/cron.mts",
    "ngrok": "ngrok http --url=intimate-certainly-opossum.ngrok-free.app 3000",
    "build": "rm -rf dist && npm run codegen && tsc && cp -r ./src/generated ./dist/generated",
    "build:pre": "npm run build:web",
    "build:web": "rm -rf static && cd ../app && NODE_ENV=production npm run web:export && cd ../server && mv ../app/dist static",
    "build:prod": "npm run build:pre && npm run build",
    "start": "prisma migrate deploy && node dist/server.mjs",
    "start:cron": "prisma migrate deploy && node dist/cron.mjs",
    "format": "prettier --write \"src/**/*.{js,ts,mjs,mts}\" && prisma format",
    "lint": "eslint \"src/**/*.{js,ts,mjs,mts}\" --fix",
    "lint:format": "npm run lint && npm run format",
    "clean": "rm -rf dist node_modules tsconfig.tsbuildinfo package-lock.json src/generated lcov.info static",
    "generate:prisma": "prisma generate",
    "codegen": "npm run generate:prisma",
    "knip": "knip"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/cryptr": "^4.0.3",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.4",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "knip": "^5.77.1",
    "prettier": "^3.6.2",
    "prisma": "^7.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clerk/express": "^1.7.52",
    "@google/genai": "^1.34.0",
    "@onerlaw/framework": "^1.0.36",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.1.0",
    "@trpc/server": "^11.7.1",
    "cors": "^2.8.5",
    "cryptr": "^6.4.0",
    "dotenv": "^17.2.3",
    "expo-server-sdk": "^3.13.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "superjson": "^2.2.5",
    "zod": "^4.1.12"
  }
}
