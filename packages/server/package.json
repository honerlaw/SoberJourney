{
  "name": "@onerlaw/soberjourney-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "OPENAI_API_KEY=test node --experimental-strip-types --experimental-test-module-mocks --experimental-test-coverage --import tsx --test **/*.test.mts",
    "start:local": "tsx --watch --no-cache --env-file=.env src/index.mts",
    "ngrok": "ngrok http --url=intimate-certainly-opossum.ngrok-free.app 3000",
    "build": "rm -rf dist && npm run codegen && tsc && cp -r ./src/generated ./dist/generated",
    "build:pre": "npm run build:web",
    "build:web": "rm -rf static && cd ../app && NODE_ENV=production npm run web:export && cd ../server && mv ../app/dist static",
    "build:image": "npx -y @onerlaw/cli@latest build",
    "deploy": "npx -y @onerlaw/cli@latest deploy",
    "start": "prisma migrate deploy && node dist/index.mjs",
    "format": "prettier --write \"src/**/*.{js,ts,mjs,mts}\"",
    "lint": "eslint \"src/**/*.{js,ts,mjs,mts}\" --fix",
    "lint:format": "npm run lint && npm run format",
    "clean": "rm -rf dist node_modules tsconfig.tsbuildinfo package-lock.json src/generated lcov.info static",
    "generate:prisma": "npx prisma generate",
    "codegen": "npm run generate:prisma"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/cryptr": "^4.0.3",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clerk/express": "^1.7.52",
    "@onerlaw/framework": "^1.0.36",
    "@trpc/server": "^11.7.1",
    "cors": "^2.8.5",
    "cryptr": "^6.4.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "prisma": "^7.0.0",
    "superjson": "^2.2.5",
    "zod": "^4.1.12"
  }
}
