{
  "name": "@onerlaw/soberjourney-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "clean": "rm -rf node_modules .vscode package-lock.json ios android .expo-env.d.ts .tamagui .expo dist expo-env.d.ts tamagui-web.css",
    "clean:dist": "rm -rf .expo .tamagui tamagui-web.css ios android .expo-env.d.ts dist $TMPDIR/react-*",
    "clean:cache": "npm run clean:dist && watchman watch-del-all",
    "build": "tsc --noEmit",
    "start": "expo start",
    "android": "expo run:android",
    "android:localhost": "adb reverse tcp:3000 tcp:3000",
    "ios": "expo run:ios",
    "ios:clean": "npm run clean:cache && npm run ios --clear",
    "web": "expo start --web --clear",
    "web:export": "npm run clean:dist && expo export --clear -p web",
    "lint": "expo lint",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:format": "expo lint --fix && npm run format",
    "test": "echo \"Error: no test specified\"",
    "eas:submit": "eas build --non-interactive --auto-submit --platform ios --no-wait",
    "doctor": "npx -y expo-doctor",
    "doctor:fix": "npx expo install --check",
    "knip": "knip"
  },
  "dependencies": {
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@clerk/clerk-expo": "^2.19.4",
    "@expo/vector-icons": "^15.0.3",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tamagui/babel-plugin": "^1.138.2",
    "@tamagui/config": "^1.138.2",
    "@tamagui/lucide-icons": "^1.138.2",
    "@tamagui/metro-plugin": "^1.138.2",
    "@tamagui/toast": "^1.138.2",
    "@trpc/client": "^11.7.1",
    "@trpc/tanstack-react-query": "^11.7.1",
    "boring-avatars": "^2.0.4",
    "burnt": "^0.13.0",
    "eventsource": "^4.1.0",
    "expo": "~54.0.30",
    "expo-apple-authentication": "~8.0.8",
    "expo-constants": "~18.0.10",
    "expo-font": "~14.0.9",
    "expo-glass-effect": "~0.1.8",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.0.1",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "lottie-react-native": "^7.3.4",
    "markdown-it": "^14.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "rn-eventsource-reborn": "^1.0.5",
    "superjson": "^2.2.6",
    "tamagui": "^1.138.2",
    "web-streams-polyfill": "^4.2.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.4",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "knip": "^5.77.1",
    "prettier": "^3.6.2",
    "react-native-svg-transformer": "^1.5.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
