{
  "name": "@onerlaw/soberjourney-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "clean": "rm -rf node_modules .vscode package-lock.json ios android .expo-env.d.ts .tamagui .expo dist expo-env.d.ts tamagui-web.css",
    "clean:dist": "rm -rf .expo .tamagui ios android .expo-env.d.ts dist $TMPDIR/react-*",
    "clean:cache": "npm run clean:dist && watchman watch-del-all",
    "build": "tsc --noEmit",
    "start": "expo start",
    "android": "expo start --android",
    "android:localhost": "adb reverse tcp:3000 tcp:3000",
    "ios": "expo start --ios",
    "web": "expo start --web --clear",
    "web:export": "npm run clean:dist && expo export --clear -p web",
    "lint": "expo lint",
    "lint:format": "expo lint --fix",
    "test": "echo \"Error: no test specified\""
  },
  "dependencies": {
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@clerk/clerk-expo": "^2.19.4",
    "@expo/vector-icons": "^15.0.3",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tamagui/babel-plugin": "^1.138.2",
    "@tamagui/config": "^1.138.2",
    "@tamagui/lucide-icons": "^1.138.2",
    "@tamagui/metro-plugin": "^1.138.2",
    "@tamagui/toast": "^1.138.2",
    "@trpc/client": "^11.7.1",
    "@trpc/tanstack-react-query": "^11.7.1",
    "eventsource": "^4.1.0",
    "expo": "~54.0.25",
    "expo-constants": "~18.0.10",
    "expo-font": "~14.0.9",
    "expo-glass-effect": "^0.1.7",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.9",
    "expo-router": "~6.0.15",
    "expo-secure-store": "^15.0.7",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "lottie-react-native": "^7.3.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "rn-eventsource-reborn": "^1.0.5",
    "tamagui": "^1.138.2",
    "web-streams-polyfill": "^4.2.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
