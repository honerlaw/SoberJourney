{
  "expo": {
    "name": "SoberJourney",
    "slug": "SoberJourney",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/app-icon.png",
    "scheme": "soberjourney",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.onerlaw.soberjourney",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/logo/adaptive-icon.png",
        "backgroundImage": "./assets/logo/adaptive-icon.png",
        "monochromeImage": "./assets/logo/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/icon-512.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/splash-icon-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f79c97c3-d0dd-43d0-bc42-a766540bee2b"
      }
    },
    "owner": "onerlawllc"
  }
}
