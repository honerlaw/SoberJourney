{
  "expo": {
    "name": "SoberJourney",
    "slug": "SoberJourney",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/app-icon.png",
    "scheme": "soberjourney",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.onerlaw.soberjourney",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "$(PRODUCT_NAME) needs access to your photo library to allow you to select and upload images for your profile.",
        "NSCameraUsageDescription": "$(PRODUCT_NAME) needs access to your Camera.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": {
        "light": "./assets/logo/ios-light.png",
        "dark": "./assets/logo/ios-dark.png",
        "tinted": "./assets/logo/ios-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/logo/adaptive-icon.png",
        "backgroundImage": "./assets/logo/adaptive-icon.png",
        "monochromeImage": "./assets/logo/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.onerlaw.soberjourney"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/icon-512.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/splash-icon-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/logo/splash-icon-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-apple-authentication",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f79c97c3-d0dd-43d0-bc42-a766540bee2b"
      }
    },
    "owner": "onerlawllc"
  }
}
